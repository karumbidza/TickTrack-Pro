{
  "expo": {
    "name": "TickTrack Pro",
    "slug": "ticktrack-mobile",
    "scheme": "ticktrack",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": false,
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#F6F5F1"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.ticktrackpro.mobile"
    },
    "android": {
      "package": "com.ticktrackpro.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#F6F5F1"
      }
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-font",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
