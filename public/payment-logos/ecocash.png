<script>
// Yamurai Chat Widget Tracking
window.addEventListener('load', function() {
  console.log('Chat widget tracking initialized');
  
  if (typeof gtag !== 'undefined') {
    
    // Track chat widget interactions
    document.addEventListener('click', function(e) {
      var element = e.target;
      
      // Check if click is on Yamurai chat widget
      if (element.closest('#yamurai-chat-widget') || 
          element.closest('[class*="yamurai"]') ||
          element.textContent.includes('Chat with Yamurai') ||
          element.textContent.includes('Yamurai')) {
        
        gtag('event', 'yamurai_chat_click', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'Chat_Widget_Clicked',
          'chat_action': 'click'
        });
        console.log('Yamurai chat click tracked');
      }
      
      // Track specific chat options
      var text = element.textContent || '';
      if (text.includes('Airtime Transfer')) {
        gtag('event', 'yamurai_option_select', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'Airtime_Transfer_Selected',
          'chat_option': 'airtime_transfer'
        });
        console.log('Airtime Transfer option tracked');
      }
      
      if (text.includes('Data bundle balance')) {
        gtag('event', 'yamurai_option_select', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'Data_Balance_Selected',
          'chat_option': 'data_balance'
        });
        console.log('Data balance option tracked');
      }
      
      if (text.includes('Over scratched Cards')) {
        gtag('event', 'yamurai_option_select', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'Scratched_Cards_Selected',
          'chat_option': 'scratched_cards'
        });
        console.log('Scratched cards option tracked');
      }
    });
    
    // Track when user starts typing
    document.addEventListener('input', function(e) {
      if (e.target.placeholder && e.target.placeholder.includes('Enter your name')) {
        gtag('event', 'yamurai_name_input', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'User_Started_Name_Entry',
          'chat_action': 'name_input'
        });
        console.log('User started entering name in Yamurai chat');
      }
    });
    
    // Track "Start Chat" button
    document.addEventListener('click', function(e) {
      if (e.target.textContent && e.target.textContent.includes('Start Chat')) {
        gtag('event', 'yamurai_start_chat', {
          'event_category': 'Yamurai_Chat',
          'event_label': 'Start_Chat_Button_Clicked',
          'chat_action': 'start_conversation',
          'value': 1
        });
        console.log('Start Chat button clicked');
      }
    });
    
  } else {
    console.log('Google Analytics not available for Yamurai tracking');
  }
});
</script>
