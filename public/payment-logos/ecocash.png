		<style id="wp-custom-css">
			/* Fix for Apple Pencil interaction */
/* .quadmenu-container * {
    touch-action: manipulation;
    -webkit-touch-callout: none;
    -webkit-user-select: none;
    user-select: none;
}

/* Ensure all clickable elements respond to touch */
/* .quadmenu-container a,
.quadmenu-container li,
.quadmenu-container button,
.quadmenu-container [role="button"] {
    cursor: pointer;
    touch-action: manipulation;
} */ 
#quadmenu.quadmenu-default_theme .quadmenu-navbar-nav > li:not(.quadmenu-item-type-button) > a > .quadmenu-item-content > .quadmenu-icon {
    color: #161515;
    font-size: 25px;
}
@media (min-width: 768px) and (max-width: 1300px) {
    #quadmenu .quadmenu-navbar-nav li.quadmenu-item .quadmenu-item-content {
        padding: 6px !important;
    }
}
h3.surveyTitle {
    font-size: 28px !important;
}

@media (max-width: 1300px) {
    .elms_left {
        flex: initial !important;
        display: initial !important;
        width: initial !important;
        box-shadow: initial !important;
        opacity: initial !important;
    }
}
@media (max-width: 850px) {
    #menu-item-2084,
    #menu-item-5039,
    #menu-item-2210 {
        display: none !important;
        opacity: 0 !important;
        visibility: hidden !important;
        pointer-events: none !important;
    }
#quadmenu.quadmenu-is-horizontal .quadmenu-navbar-nav li.quadmenu-item > .quadmenu-dropdown-menu {
  position: absolute;
  top: 100%;
  border-radius: 20px;
  background: linear-gradient(to right, #0066cc, #cc0000) top/100% 5px no-repeat, #ffffff 0 5px;
  min-width: 60vh;
}
#quadmenu .quadmenu-navbar-nav li.quadmenu-item .quadmenu-item-content {
    padding: 6px !important;
}
}
/* Hide the right header div from 768px and up (desktop and large tablets) */
@media (min-width: 768px) {
    .elms_right.header_4_right {
        display: none !important;
    }
}
@media (max-width: 768px) {
    .elms_center.header_4_center {
        display: none !important;
    }
}
#quadmenu.quadmenu-default_theme 
.quadmenu-navbar-nav 
.quadmenu-dropdown-menu 
li.quadmenu-item > a > .quadmenu-item-content {
    position: relative;
    overflow: hidden;
    font-size: 18px !important;
	  padding-bottom: 10px;
}

.bg-gradient {
    background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%) !important;
}

/* Shimmer effect with blue and red */
#quadmenu.quadmenu-default_theme 
.quadmenu-navbar-nav 
.quadmenu-dropdown-menu 
li.quadmenu-item > a > .quadmenu-item-content:hover::before {
    content: '';
    position: absolute;
    top: 0;
    left: -100%;
    width: 200%;
    height: 100%;
    background: linear-gradient(
        120deg,
        rgba(0, 0, 255, 0.1) 0%,
        rgba(255, 0, 0, 0.3) 50%,
        rgba(0, 0, 255, 0.1) 100%
    );
    animation: shimmer-blue-red 1.5s linear infinite;
    pointer-events: none;
    z-index: 2;
    transform: skewX(-20deg);
}

@keyframes shimmer-blue-red {
    0% {
        left: -100%;
    }
    100% {
        left: 100%;
    }
}

/* White shimmer effect on hover */
#quadmenu.quadmenu-default_theme 
.quadmenu-navbar-nav 
.quadmenu-dropdown-menu 
li.quadmenu-item > a > .quadmenu-item-content:hover::after {
    content: '';
    position: absolute;
    top: 0;
    left: -75%;
    width: 50%;
    height: 100%;
    background: linear-gradient(
        120deg,
        rgba(255, 255, 255, 0) 0%,
        rgba(255, 255, 255, 0.4) 50%,
        rgba(255, 255, 255, 0) 100%
    );
    animation: shimmer 1.2s infinite;
    pointer-events: none;
    z-index: 2;
    transform: skewX(-20deg);
}

@keyframes shimmer {
    0% {
        left: -75%;
    }
    100% {
        left: 125%;
    }
}

#quadmenu .quadmenu-navbar-nav li.quadmenu-item .quadmenu-item-widget {
    padding: 0px !important;
    background: none;
    border-style: none;
}

#quadmenu.quadmenu-default_theme {
    background-color: #fff;
    color: #03183B;
    font-weight: 400;
    font-size: 18px !important;
    font-style: normal;
    letter-spacing: inherit;
    position: relative;
}

#quadmenu.quadmenu-default_theme .quadmenu-navbar-nav > li:not(.quadmenu-item-type-button) > a > .quadmenu-item-content {
    color: #03183B;
    font-weight: 400;
    font-size: 18px !important;
    letter-spacing: auto;
    text-transform: capitalize;
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
}

#quadmenu.quadmenu-default_theme .quadmenu-navbar-nav > li.quadmenu-item > a, 
#quadmenu.quadmenu-default_theme .quadmenu-navbar-nav > li.quadmenu-item > form {
    font-family: "Helvetica Neue", Helvetica, Arial, sans-serif;
    color: #03183B;
    font-size: 18px !important;
    font-weight: 400;
    font-style: normal;
    letter-spacing: inherit;
    background: #fff !important;
    text-transform: capitalize;
}

#quadmenu .quadmenu-navbar-nav li.quadmenu-item > a > .quadmenu-item-content > .quadmenu-text {
    display: inline-block;
    font-size: 18px !important;
    font-weight: 400;
    color: #03183B;
}

header .row {
    width: 100%;
    font-size: 18px !important;
}

#quadmenu.quadmenu-is-horizontal .quadmenu-navbar-nav li.quadmenu-item > .quadmenu-dropdown-menu {
    position: absolute;
    top: 100%;
    border-radius: 20px;
    background: linear-gradient(to right, #0066cc, #cc0000) top/100% 5px no-repeat,
                #ffffff 0 5px; 
}

.elms_center > div {
  margin-left: 0px !important;
  display: flex;
}

.elms_left {
  flex:  20% !important;
  display: block;
  width: 100%;
	box-shadow: 1px 0px 5px #00000021;
opacity: 1;
}
.have_center .elms_center {
  margin-left: 5px;
  flex-basis: 65% !important;
}

.elms_right {
  flex: 10% !important;
  display: block;
  width: 100%;
  padding-left:2%;
}



.box-shadow{
	box-shadow: 10px 10px 6px 1px rgba(56,53,53,0.36);
-webkit-box-shadow: 10px 10px 6px 1px rgba(56,53,53,0.36);
-moz-box-shadow: 10px 10px 6px 1px rgba(56,53,53,0.36);
}
.glass-effect{
background: rgba(255, 255, 255, 0.24);
border-radius: 1px;
box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
backdrop-filter: blur(8.5px);
-webkit-backdrop-filter: blur(8.5px);
border: 1px solid rgba(255, 255, 255, 0.2);
}

.tab_section_shadow{
	backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
	padding: 3% !important;
     border-radius: 20px;
    box-shadow: -1px 4px 18px rgba(0, 0, 0, 0.1);
}
.cz_btn{
            padding: 15px 35px !important;
            
            text-decoration: none;
            transition: all 0.3s ease!important;
            backdrop-filter: blur(20px)!important;
            font-weight: 400;
            text-transform: uppercase!important;
            letter-spacing: 1px;
            font-size: 0.9rem;
            border-radius: 50px !important;}
.profile_shadow{
	backdrop-filter: blur(20px);
  border: 1px solid rgba(255, 255, 255, 0.2);
     border-radius: 20px;
    box-shadow: -1px 4px 18px rgba(0, 0, 0, 0.1);
}
@media (max-width: 768px) {
    .table-row td {
        padding: 20px 25px;
        font-size: 11px;
        color: rgba(0, 0, 0, 0.8);
        border-bottom: 1px solid rgba(0, 0, 0, 0.06);
        transition: all 0.3s ease;
        font-weight: 500;
    }
}
#yamurai-chat-widget, .chat-widget-container
 {
    border: none !important;
        -webkit-backdrop-filter: none !important;
    backdrop-filter: none !important;
    overflow: visible !important;
}
		</style>
